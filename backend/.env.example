# Copy to backend/.env

# Cloud SQL (Unix socket via Cloud Run connector)
# DATABASE_URL=postgresql://jaybel:PASSWORD@/jaybel_sales_app?host=/cloudsql/jaybel-dev:us-central1:jaybel-sales-db

# Local dev (docker-compose postgres on port 15433)
DATABASE_URL=postgresql://jaybel:jaybel_local_dev@localhost:15433/jaybel_sales_app

# GCP — Agent Engine + BigQuery
GOOGLE_CLOUD_PROJECT=jaybel-dev
GOOGLE_CLOUD_LOCATION=us-central1
AGENT_ENGINE_RESOURCE=projects/115724636423/locations/us-central1/reasoningEngines/8991351443894042624
FIREBASE_PROJECT_ID=jaybel-dev

# API
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Local dev only: skip Firebase (uses seeded user from 001_initial.sql)
# AUTH_DISABLED=true
# DEFAULT_USER_ID=00000000-0000-4000-8000-000000000001
