# Copy to backend/.env

# Local PostgreSQL (app data: users, sessions, chat turns)
DATABASE_URL=postgresql://jaybel:jaybel_local_dev@localhost:15433/jaybel_sales_app

# GCP — Agent Engine + BigQuery (analytics queries still run in cloud)
GOOGLE_CLOUD_PROJECT=jaybel-dev
GOOGLE_CLOUD_LOCATION=us-central1
AGENT_ENGINE_RESOURCE=projects/115724636423/locations/us-central1/reasoningEngines/8991351443894042624

# API
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Default local user (matches sql/migrations/001_initial.sql)
DEFAULT_USER_ID=00000000-0000-4000-8000-000000000001
