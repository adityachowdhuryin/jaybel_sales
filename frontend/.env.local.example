# Copy to frontend/.env.local — local app (no Firebase)

# Local FastAPI (sessions + chat SSE proxy to Agent Engine)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: only if frontend must know project/region for display
NEXT_PUBLIC_GCP_PROJECT_ID=jaybel-dev
NEXT_PUBLIC_GCP_LOCATION=us-central1

# Agent Engine is called from the backend, not the browser (preferred).
# If needed for debugging only:
# NEXT_PUBLIC_AGENT_ENGINE_ID=8991351443894042624
