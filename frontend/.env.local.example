# Copy to frontend/.env.local after Firebase Web app + Agent Engine deploy
# Local UI: npm run dev → http://localhost:3000

NEXT_PUBLIC_GCP_PROJECT_ID=jaybel-dev
NEXT_PUBLIC_GCP_LOCATION=us-central1

# Vertex AI Agent Engine (see agent/AGENT_ENGINE_RESOURCE.env)
NEXT_PUBLIC_AGENT_ENGINE_ID=8991351443894042624
NEXT_PUBLIC_AGENT_ENGINE_RESOURCE=projects/115724636423/locations/us-central1/reasoningEngines/8991351443894042624

# Firebase Web SDK (Firebase Console → Project jaybel-dev → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=jaybel-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=jaybel-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
