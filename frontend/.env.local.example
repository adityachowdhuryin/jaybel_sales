# Copy to frontend/.env.local

# Cloud Run API (after deploy-backend.sh)
NEXT_PUBLIC_API_BASE_URL=https://jaybel-sales-api-xxxxx-uc.a.run.app

# Firebase Web app config (Firebase Console → Project settings)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=jaybel-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=jaybel-dev

# Optional display
NEXT_PUBLIC_GCP_PROJECT_ID=jaybel-dev
NEXT_PUBLIC_GCP_LOCATION=us-central1

# Local dev without Firebase: leave FIREBASE_API_KEY empty and set backend AUTH_DISABLED=true
